# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Generative AI / Gemini (Budget AI Assistant, Pantry Meal Assistant)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional model override, defaults to gemini-3.1-flash-lite
GEMINI_MODEL=

# USDA FoodData Central (free, no key required for basic search)
USDA_API_KEY=DEMO_KEY

# Nutritionix (optional fallback, free tier 500 req/day)
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# Garmin Connect OAuth
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Bevel Health OAuth
BEVEL_CLIENT_ID=
BEVEL_CLIENT_SECRET=
BEVEL_API_BASE_URL=

# Canvas LMS (user-provided per account, stored in DB — not needed here)
# CANVAS_INSTANCE_URL and CANVAS_API_TOKEN are stored per-user in integration_tokens

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
